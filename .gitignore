# Derived build artifacts — rebuild with: stedt build / stedt render
stedt.sqlite
*.sqlite
*.sqlite3
search.db
site/
# refactor-verification snapshots (stedt snapshot); regenerate on demand
.snapshots/

# Node (search bundle build deps); package-lock.json IS tracked for reproducible CI
node_modules/

# Original UC Berkeley release (provenance; archived separately, not the editable source).
# data/ is the source of truth; build_db.py is the one-time migration that needs the dump.
stedtdb_v1.0/*.sql
stedtdb_v1.0/*.csv
stedtdb_v1.0/*.bz2
stedtdb_v1.0/*.RData
stedtdb_v1.0/*.pdf
stedtdb_v1.0/._*

# Original release archive (provenance; archived separately)
*.tgz

# macOS junk
._*
.DS_Store

# Python
__pycache__/
*.pyc

# Python packaging (`pip install .` build artifacts; leading slash keeps the tracked
# stedt/build/ package safe — only the top-level setuptools build/ dir is ignored)
/build/
*.egg-info/

# JetBrains IDE
.idea/
